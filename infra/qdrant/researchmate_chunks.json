{
  "collection": "researchmate_chunks",
  "vectors": {
    "dense": {
      "size": 4096,
      "distance": "Cosine"
    }
  },
  "sparse_vectors": {
    "sparse": {
      "modifier": "idf"
    }
  },
  "fusion": "rrf",
  "payload_schema": {
    "user_id": "keyword",
    "project_id": "keyword",
    "document_id": "keyword",
    "chunk_id": "keyword",
    "source_type": "keyword",
    "page_no": "integer",
    "slide_no": "integer",
    "title": "text",
    "url": "keyword",
    "content_hash": "keyword",
    "pipeline_version": "keyword",
    "expires_at": "datetime"
  },
  "required_filters": ["user_id", "project_id", "source_type"]
}
