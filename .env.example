# Frontend public configuration
APP_ENV=local
AUTH_MODE=development
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_public_anon_key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Supabase backend configuration
REPOSITORY_BACKEND=memory
DATABASE_URL=postgresql://postgres:replace_with_password@db.example.supabase.co:5432/postgres
SUPABASE_URL=https://example.supabase.co
SUPABASE_JWKS_URL=https://example.supabase.co/auth/v1/.well-known/jwks.json

# Cloudflare R2 backend configuration
R2_ACCOUNT_ID=replace_with_r2_account_id
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_backend_only_r2_secret
R2_BUCKET=researchmate-dev

# Vector database
QDRANT_URL=https://replace-with-development-cluster.cloud.qdrant.io
QDRANT_API_KEY=replace_with_qdrant_key_if_needed
QDRANT_COLLECTION=researchmate_chunks

# LLM and embedding providers
LLM_PROVIDER=fake
NVIDIA_API_KEY=replace_with_backend_only_nvidia_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm-5.2
LLM_TEMPERATURE=1
LLM_TOP_P=1
LLM_MAX_TOKENS=16384
LLM_SEED=42
LLM_TIMEOUT_SECONDS=120
WORKFLOW_CALL_BUDGET_RESERVATION_USD=0.25
WORKFLOW_MAX_PROMPT_TOKENS=32768
NVIDIA_INPUT_COST_PER_MILLION_USD=replace_with_current_provider_price
NVIDIA_OUTPUT_COST_PER_MILLION_USD=replace_with_current_provider_price
EMBEDDING_PROVIDER=fake
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embed-v1
EMBEDDING_DIMENSION=4096

# Search and crawl providers
WEB_SEARCH_PROVIDER=disabled
TAVILY_API_KEY=replace_with_backend_only_tavily_key
TAVILY_BASE_URL=https://api.tavily.com
WEB_SEARCH_TIMEOUT_SECONDS=30

# Cache, jobs, and API limits
REDIS_URL=rediss://default:replace_with_upstash_password@replace-with-development-redis.upstash.io:6379
RUNTIME_HEARTBEAT_MAX_AGE_SECONDS=150
OUTBOX_PENDING_MAX_AGE_SECONDS=180
RUNTIME_HEARTBEAT_SECONDS=30
WORKFLOW_LEASE_SECONDS=900
RESEARCHMATE_PROCESS_ROLE=worker
ACCESS_TOKEN_ISSUER=https://example.supabase.co/auth/v1
ACCESS_TOKEN_AUDIENCE=authenticated
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_BYTES=26214400
DOCLING_ARTIFACTS_PATH=D:\software\env\researchmate\models\docling
LANGGRAPH_STRICT_MSGPACK=true
RAGAS_DO_NOT_TRACK=true
DEFAULT_PROJECT_TTL_DAYS=7

# Observability (disabled locally; required and separately keyed in preview/production)
LOG_LEVEL=INFO
OTEL_ENABLED=false
OTEL_SERVICE_NAME=researchmate-api
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://replace-with-collector.example/v1/traces
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=replace_with_langfuse_public_key
LANGFUSE_SECRET_KEY=replace_with_langfuse_secret_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
