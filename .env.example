# Frontend public configuration
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_public_anon_key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Supabase backend configuration
SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_backend_only_service_role_key

# Cloudflare R2 backend configuration
R2_ACCOUNT_ID=replace_with_r2_account_id
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_backend_only_r2_secret
R2_BUCKET=researchmate-dev

# Vector database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=replace_with_qdrant_key_if_needed
QDRANT_COLLECTION=researchmate_chunks

# LLM and embedding providers
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=replace_with_backend_only_nvidia_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=replace_with_selected_nvidia_model
EMBEDDING_PROVIDER=nvidia
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embed-v1

# Search and crawl providers
SERPER_API_KEY=replace_with_backend_only_serper_key
TAVILY_API_KEY=replace_with_backend_only_tavily_key
JINA_API_KEY=replace_with_backend_only_jina_key
FIRECRAWL_API_KEY=replace_with_backend_only_firecrawl_key

# Cache, jobs, and API limits
REDIS_URL=redis://localhost:6379/0
ACCESS_TOKEN_ISSUER=https://example.supabase.co/auth/v1
ACCESS_TOKEN_AUDIENCE=authenticated
CORS_ALLOWED_ORIGINS=http://localhost:3000
MAX_UPLOAD_BYTES=26214400
DEFAULT_PROJECT_TTL_DAYS=7

