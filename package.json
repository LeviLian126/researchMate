{
  "name": "researchmate",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "overrides": {
    "postcss": "8.5.10"
  },
  "scripts": {
    "check:contracts": "python -m pytest tests/test_project_scaffold.py tests/test_api_workflow.py tests/test_frontend_contracts.py -q",
    "check:docs": "python -m pytest tests/test_project_scaffold.py -q",
    "api:dev": "python -m uvicorn researchmate_api.main:app --app-dir apps/api/src --reload --host 127.0.0.1 --port 8000",
    "web:dev": "npm --workspace @researchmate/web run dev",
    "test": "python -m pytest -q",
    "check:api": "python -m pytest tests/test_api_workflow.py -q",
    "check:frontend-contracts": "python -m pytest tests/test_frontend_contracts.py -q",
    "check:lint": "python -m ruff check apps/api/src workers/ai-worker/src tests",
    "check:web": "npm --workspace @researchmate/web run build",
    "check:audit": "npm audit --omit=dev --audit-level=moderate",
    "check:openapi": "python scripts/export_openapi.py --check",
    "check:migrations": "python scripts/apply_migrations.py --check-files",
    "check:all": "npm run test && npm run check:lint && npm run check:openapi && npm run check:migrations && npm run check:web && npm run check:audit"
  }
}
